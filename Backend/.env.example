# NutriLens Backend - Environment Variables Configuration
# Copy this file to .env and configure values.

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB URI)
# Example: MONGODB_URI=mongodb://localhost:27017/nutrilens
MONGODB_URI=mongodb://localhost:27017/nutrilens

# JWT Secret Keys
JWT_ACCESS_SECRET=your_super_secret_access_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me_in_production

# CORS Client Settings
CLIENT_URL=http://localhost:5173
